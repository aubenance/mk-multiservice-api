# ============================================================
#  MK MULTISERVICE — Variables d'environnement
#  Copiez ce fichier en ".env" et remplissez vos valeurs
# ============================================================

# ── Serveur ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Supabase ─────────────────────────────────────────────
# Disponible dans : Supabase Dashboard > Settings > API
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici
SUPABASE_ANON_KEY=votre_anon_key_ici

# ── JWT (Authentification) ───────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_CE_SECRET_AVEC_UNE_CLÉ_TRÈS_LONGUE_ET_ALÉATOIRE
JWT_EXPIRES=8h

# ── CORS (Origines autorisées) ───────────────────────────
# En production, mettez l'URL de votre application
ALLOWED_ORIGINS=http://localhost:3000,https://votre-domaine.com
